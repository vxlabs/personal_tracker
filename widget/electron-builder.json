{
  "appId": "com.vxlabs.protocol",
  "productName": "Protocol",
  "icon": "assets/icon.png",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "assets/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "dist/frontend",
      "to": "frontend",
      "filter": ["**/*"]
    },
    {
      "from": "resources/api",
      "to": "api",
      "filter": ["**/*"]
    },
    {
      "from": "assets",
      "to": "assets",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": ["nsis"]
  },
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.productivity"
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false
  }
}
