{
  "name": "protocol-desktop",
  "version": "1.1.0",
  "description": "Protocol desktop app with embedded API and always-on-top widget",
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "npm run build && concurrently \"npm run build:renderer:watch\" \"npm run build:main:watch\" \"npm run electron:dev\"",
    "dev:ext-api": "npm run build && concurrently \"npm run build:renderer:watch\" \"npm run build:main:watch\" \"npm run electron:dev:ext-api\"",
    "electron:dev": "wait-on file:dist/main/main/main.js file:dist/renderer/index.html && electron .",
    "electron:dev:ext-api": "wait-on file:dist/main/main/main.js file:dist/renderer/index.html && cross-env PROTOCOL_API_BASE_URL=http://localhost:5000 electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:main:watch": "tsc -p tsconfig.main.json --watch",
    "build:renderer": "vite build",
    "build:renderer:watch": "vite build --watch",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "generate-extension-key": "node ../scripts/generate-extension-key.js"
  },
  "keywords": [],
  "author": "Sadique",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
