{
  "manifest_version": 3,
  "name": "Protocol Enforcer",
  "version": "1.0.0",
  "description": "Enforces your Protocol schedule — blocks distracting sites during focus blocks.",

  "_comment_key": "Generate this key once with: npm run generate-extension-key (see scripts/). Paste the output here to get a stable extension ID. Without it each unpacked install gets a random ID and the desktop app cannot whitelist it.",
  "key": "",

  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "idle",
    "nativeMessaging"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "<all_urls>"
  ],
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_end"
  }],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Protocol"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
